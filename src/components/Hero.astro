---
const base = import.meta.env.BASE_URL;
const heroBg = `${base.replace(/\/$/, '')}/img/hero-bg.jpg`;
---
<section class="relative min-h-[88vh] flex items-center overflow-hidden">
  <img
    src={heroBg}
    alt=""
    aria-hidden="true"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover opacity-60"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-slate-950/70 via-slate-950/55 to-[color:var(--color-bg)]"></div>
  <div class="absolute inset-0 pointer-events-none" style="background:
    radial-gradient(ellipse at top, rgba(34, 211, 238, 0.18), transparent 55%),
    repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(148, 163, 184, 0.04) 40px),
    repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(148, 163, 184, 0.04) 40px);"></div>

  <div class="relative max-w-4xl mx-auto px-6 py-24 text-center">
    <p class="inline-block px-3 py-1 text-xs font-mono uppercase tracking-widest text-cyan-300 border border-cyan-400/40 rounded-full backdrop-blur-sm bg-slate-950/30">
      Sentinel · drone inspection platform
    </p>
    <h1 class="mt-8 text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight text-white drop-shadow-[0_2px_24px_rgba(0,0,0,0.6)]">
      AI-driven asset inspection.
      <span class="block text-cyan-400 mt-2">Built for the field.</span>
    </h1>
    <p class="mt-6 text-lg text-slate-300 max-w-2xl mx-auto drop-shadow-[0_2px_16px_rgba(0,0,0,0.7)]">
      End-to-end drone surveys for utility and infrastructure assets — capture, auto-annotate, reconstruct in 3D, and dispatch work orders, all on one platform.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href="https://sntl.live"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-cyan-500 text-slate-950 font-medium hover:bg-cyan-400 transition-colors shadow-lg shadow-cyan-500/20"
      >
        Visit product
        <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a
        href="#how-it-works"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md border border-slate-600 text-slate-100 hover:border-cyan-500 hover:text-cyan-300 backdrop-blur-sm bg-slate-950/30 transition-colors"
      >
        See how it works ↓
      </a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-[color:var(--color-bg)]"></div>
</section>
