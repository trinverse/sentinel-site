---
const year = new Date().getFullYear();
---
<footer class="border-t border-[color:var(--color-border)] py-10">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
    <p>© {year} Sentinel. Built for the field.</p>
    <div class="flex items-center gap-6">
      <a href="https://sntl.live" class="hover:text-cyan-400 transition-colors">sntl.live</a>
      <span class="text-slate-700">·</span>
      <span>Built with <a class="hover:text-cyan-400" href="https://astro.build">Astro</a></span>
    </div>
  </div>
</footer>
