---
const stages = [
  { num: '01', title: 'Capture', body: 'Drone flights or manual uploads. Visual + thermal, georeferenced.' },
  { num: '02', title: 'AI annotation', body: 'YOLO26 detects defects, drafts annotations in W3C format.' },
  { num: '03', title: 'Review', body: 'Pilots and inspectors approve, reject, or refine draft findings.' },
  { num: '04', title: 'Work orders', body: 'Approved findings spawn tickets and auto-route to the right team.' },
  { num: '05', title: 'Reports', body: 'Branded PDF reports per asset, survey, or program — on demand.' },
];
---
<section id="how-it-works" class="border-t border-[color:var(--color-border)] py-24 bg-[color:var(--color-bg-elevated)]/40">
  <div class="max-w-6xl mx-auto px-6">
    <header class="max-w-2xl">
      <p class="text-sm font-mono uppercase tracking-widest text-cyan-400">How it works</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold">From flight to fix, in five stages.</h2>
    </header>

    <ol class="mt-14 grid grid-cols-1 md:grid-cols-5 gap-6 relative">
      <div class="hidden md:block absolute top-6 left-12 right-12 h-px bg-gradient-to-r from-transparent via-cyan-900 to-transparent" aria-hidden="true"></div>

      {stages.map(({ num, title, body }) => (
        <li class="relative">
          <div class="flex md:flex-col items-start md:items-center gap-4 md:gap-3">
            <span class="relative z-10 w-12 h-12 rounded-full border border-cyan-700 bg-[color:var(--color-bg)] flex items-center justify-center font-mono text-sm text-cyan-300">
              {num}
            </span>
            <div class="md:text-center">
              <h3 class="font-semibold text-slate-100">{title}</h3>
              <p class="mt-1 text-sm text-slate-400 leading-relaxed">{body}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
