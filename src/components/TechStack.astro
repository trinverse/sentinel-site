---
const tech = [
  'FastAPI', 'React', 'PostgreSQL', 'PostGIS', 'Celery',
  'Redis', 'MinIO', 'NodeODM', 'YOLO26', 'Three.js',
  'Leaflet', 'Docker',
];
---
<section class="border-t border-[color:var(--color-border)] py-20">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <p class="text-sm font-mono uppercase tracking-widest text-cyan-400">Built with</p>
    <ul class="mt-6 flex flex-wrap items-center justify-center gap-3">
      {tech.map((name) => (
        <li class="mono px-3 py-1.5 text-xs rounded-md border border-slate-800 text-slate-300 hover:border-cyan-700 hover:text-cyan-300 transition-colors">
          {name}
        </li>
      ))}
    </ul>
  </div>
</section>
