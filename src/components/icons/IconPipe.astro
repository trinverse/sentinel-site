---
interface Props { class?: string; label?: string; }
const { class: cls = 'w-6 h-6', label } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
>
  <path d="M3 8h7a4 4 0 0 1 4 4v4a4 4 0 0 0 4 4h3" />
  <path d="M3 5v6M21 19v-6" />
</svg>
