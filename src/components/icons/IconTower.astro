---
interface Props { class?: string; label?: string; }
const { class: cls = 'w-6 h-6', label } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
>
  <path d="M12 8v13" />
  <path d="M5 4c3 3 3 8 0 11M19 4c-3 3-3 8 0 11" />
  <path d="M8 6c2 2 2 5 0 7M16 6c-2 2-2 5 0 7" />
  <circle cx="12" cy="8" r="1.5" />
</svg>
