---
interface Props { class?: string; label?: string; }
const { class: cls = 'w-6 h-6', label } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  role={label ? 'img' : undefined}
>
  <path d="M13 3 7 13h4l-1 8 7-11h-4z" />
</svg>
