---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Box {
  x: number; y: number; w: number; h: number;
  label: string;
  color: 'cyan' | 'orange';
}

interface View {
  id: string;
  src: string;
  caption: string;
  surveyId: string;
  breadcrumb: string;
  boxes: Box[];
}

const views: View[] = [
  {
    id: '1',
    src: `${base}/img/defect-power.jpg`,
    caption: 'Power transmission — insulator + corrosion',
    surveyId: 'PWR-2026-0142',
    breadcrumb: 'Power Corridor 7 · Tower 23',
    boxes: [
      { x: 310, y: 182, w: 60,  h: 130, label: 'cracked-insulator 92%', color: 'cyan' },
      { x: 560, y: 302, w: 120, h: 80,  label: 'corrosion 78%',          color: 'orange' },
    ],
  },
  {
    id: '2',
    src: `${base}/img/defect-telecom.jpg`,
    caption: 'Telecom — antenna alignment + mount wear',
    surveyId: 'TLC-2026-0087',
    breadcrumb: 'Telecom Site Alpha · Antenna 4A',
    boxes: [
      { x: 480, y: 112, w: 130, h: 95, label: 'antenna-misalign 87%', color: 'cyan' },
      { x: 540, y: 227, w: 100, h: 75, label: 'mount-corrosion 72%', color: 'orange' },
    ],
  },
  {
    id: '3',
    src: `${base}/img/defect-pipeline.jpg`,
    caption: 'Pipeline — valve wear + joint condition',
    surveyId: 'PPL-2026-0029',
    breadcrumb: 'Pipeline Section 12 · Valve Bank',
    boxes: [
      { x: 470, y: 197, w: 110, h: 95, label: 'valve-corrosion 84%', color: 'cyan' },
      { x: 605, y: 322, w: 145, h: 100, label: 'joint-wear 68%',     color: 'orange' },
    ],
  },
  {
    id: '4',
    src: `${base}/img/defect-solar.jpg`,
    caption: 'Solar — hot spot + dead cell',
    surveyId: 'SOL-2026-0156',
    breadcrumb: 'Solar Array B · Row 14',
    boxes: [
      { x: 340, y: 192, w: 70, h: 60, label: 'hot-spot 91%', color: 'cyan' },
      { x: 530, y: 322, w: 85, h: 70, label: 'dead-cell 82%', color: 'orange' },
    ],
  },
];

interface SidebarRow { id: string; title: string; tag: string; dot: string; }
const sidebar: SidebarRow[] = [
  { id: '1', title: 'Tower 23',      tag: 'PWR-7 · May 12',  dot: '#22d3ee' },
  { id: '2', title: 'Antenna 4A',    tag: 'TLC-2 · May 09',  dot: '#f59e0b' },
  { id: '3', title: 'Pipeline 12',   tag: 'PPL-3 · May 06',  dot: '#22d3ee' },
  { id: '4', title: 'Solar Array B', tag: 'SOL-1 · May 02',  dot: '#f59e0b' },
];

const colorMap = { cyan: '#22d3ee', orange: '#f59e0b' };
---
<section class="border-t border-[color:var(--color-border)] py-24">
  <div class="max-w-6xl mx-auto px-6">
    <header class="max-w-2xl">
      <p class="text-sm font-mono uppercase tracking-widest text-cyan-400">A look inside</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold">Designed for inspectors and pilots.</h2>
    </header>

    <div class="mt-12 space-y-16">
      {/* Mockup 1: Survey detail — interactive image switcher */}
      <figure>
        <svg
          id="surveyMockup"
          viewBox="0 0 800 540"
          class="w-full rounded-lg border border-slate-800"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="Survey detail screen mockup — click thumbnails or sidebar to switch defects"
        >
          {/* browser chrome */}
          <rect x="0" y="0" width="800" height="32" fill="#11141a"/>
          <circle cx="16" cy="16" r="4" fill="#475569"/>
          <circle cx="32" cy="16" r="4" fill="#475569"/>
          <circle cx="48" cy="16" r="4" fill="#475569"/>
          <rect x="200" y="10" width="400" height="14" rx="3" fill="#1e293b"/>

          <rect x="0" y="32" width="800" height="508" fill="#0a0c10"/>

          {/* ====== SIDEBAR ====== */}
          <rect x="0" y="32" width="180" height="508" fill="#11141a"/>
          {/* brand */}
          <g transform="translate(16, 50)">
            <path d="M8 0 L16 5 L16 13 L8 18 L0 13 L0 5 Z" fill="none" stroke="#22d3ee" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="8" cy="9" r="2" fill="#22d3ee"/>
            <text x="26" y="13" fill="#e5e7eb" font-family="sans-serif" font-size="12" font-weight="600">Sentinel</text>
          </g>
          <line x1="16" y1="82" x2="164" y2="82" stroke="#1f2937"/>

          {/* section label + search */}
          <text x="16" y="100" fill="#64748b" font-family="monospace" font-size="9" letter-spacing="1">RECENT SURVEYS</text>
          <rect x="16" y="108" width="148" height="22" rx="11" fill="#0a0c10" stroke="#1e293b"/>
          <circle cx="28" cy="119" r="3.5" fill="none" stroke="#475569" stroke-width="1"/>
          <line x1="30.5" y1="121.5" x2="33" y2="124" stroke="#475569" stroke-width="1"/>
          <text x="40" y="123" fill="#475569" font-family="sans-serif" font-size="10">Search…</text>

          {/* sidebar items (static layout, active state varies per view) */}
          {sidebar.map((row, i) => {
            const y = 144 + i * 50;
            return (
              <g class="sidebar-item" data-target={row.id} style="cursor:pointer">
                {/* background hit area */}
                <rect class="sidebar-bg" x="8" y={y} width="164" height="42" rx="4" fill="transparent"/>
                {/* status dot */}
                <circle cx="20" cy={y + 14} r="3" fill={row.dot}/>
                <text x="32" y={y + 17} fill="#e5e7eb" font-family="sans-serif" font-size="11" font-weight="600">{row.title}</text>
                <text x="32" y={y + 32} fill="#64748b" font-family="monospace" font-size="9">{row.tag}</text>
              </g>
            );
          })}

          {/* layers section */}
          <line x1="16" y1="360" x2="164" y2="360" stroke="#1f2937"/>
          <text x="16" y="378" fill="#64748b" font-family="monospace" font-size="9" letter-spacing="1">LAYERS</text>
          {[
            { label: 'Visual',  enabled: true },
            { label: 'Thermal', enabled: false },
            { label: 'GIS overlay', enabled: true },
          ].map((layer, i) => {
            const y = 388 + i * 22;
            return (
              <g>
                <rect x="16" y={y} width="20" height="10" rx="5" fill={layer.enabled ? '#0e7490' : '#1e293b'}/>
                <circle cx={layer.enabled ? 31 : 21} cy={y + 5} r="3.5" fill="#e5e7eb"/>
                <text x="44" y={y + 8} fill="#cbd5e1" font-family="sans-serif" font-size="10">{layer.label}</text>
              </g>
            );
          })}

          {/* user chip at bottom */}
          <line x1="16" y1="500" x2="164" y2="500" stroke="#1f2937"/>
          <circle cx="28" cy="518" r="9" fill="#0e7490"/>
          <text x="28" y="522" fill="#e5e7eb" font-family="sans-serif" font-size="9" font-weight="700" text-anchor="middle">AT</text>
          <text x="44" y="516" fill="#e5e7eb" font-family="sans-serif" font-size="10" font-weight="600">Ashish T.</text>
          <text x="44" y="528" fill="#64748b" font-family="monospace" font-size="9">Inspector · Org Admin</text>

          {/* ====== TOOLBAR (above image, right of sidebar) ====== */}
          <rect x="180" y="32" width="620" height="48" fill="#11141a"/>
          <line x1="180" y1="80" x2="800" y2="80" stroke="#1f2937"/>

          {/* back chevron + breadcrumb/title — text varies per view */}
          <path d="M204 56 L210 50 M204 56 L210 62" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          {views.map((v, i) => (
            <g class="toolbar-meta" data-view={v.id} style={i === 0 ? '' : 'display:none'}>
              <text x="220" y="52" fill="#64748b" font-family="monospace" font-size="9" letter-spacing="0.5">{v.breadcrumb.toUpperCase()}</text>
              <text x="220" y="70" fill="#e5e7eb" font-family="sans-serif" font-size="14" font-weight="600">Survey #{v.surveyId}</text>
            </g>
          ))}

          {/* right-side action buttons (static) */}
          {/* filter icon */}
          <g transform="translate(620, 46)">
            <rect x="0" y="0" width="22" height="22" rx="4" fill="#0a0c10" stroke="#1e293b"/>
            <path d="M6 7 L16 7 M8 11 L14 11 M10 15 L12 15" stroke="#94a3b8" stroke-width="1.3" stroke-linecap="round" fill="none"/>
          </g>
          {/* download icon */}
          <g transform="translate(648, 46)">
            <rect x="0" y="0" width="22" height="22" rx="4" fill="#0a0c10" stroke="#1e293b"/>
            <path d="M11 5 L11 13 M7 10 L11 14 L15 10 M6 17 L16 17" stroke="#94a3b8" stroke-width="1.3" stroke-linecap="round" fill="none"/>
          </g>
          {/* reject pill */}
          <rect x="678" y="46" width="50" height="22" rx="11" fill="transparent" stroke="#7f1d1d"/>
          <text x="703" y="61" fill="#fca5a5" font-family="sans-serif" font-size="10" font-weight="600" text-anchor="middle">Reject</text>
          {/* approve pill */}
          <rect x="734" y="46" width="56" height="22" rx="11" fill="#0e7490" stroke="none"/>
          <text x="762" y="61" fill="#0a0c10" font-family="sans-serif" font-size="10" font-weight="700" text-anchor="middle">Approve</text>

          {/* ====== IMAGE AREA ====== */}
          <defs>
            <clipPath id="surveyImgClip">
              <rect x="200" y="88" width="580" height="380" rx="4" />
            </clipPath>
          </defs>
          <rect x="200" y="88" width="580" height="380" rx="4" fill="#11141a"/>

          {/* per-view stack — image + boxes + sidebar highlight */}
          {views.map((v, i) => (
            <g class="survey-view" data-view={v.id} style={i === 0 ? '' : 'display:none'}>
              {/* sidebar active rail */}
              <rect x="0" y={144 + (parseInt(v.id) - 1) * 50} width="3" height="42" fill="#22d3ee"/>
              <rect x="8" y={144 + (parseInt(v.id) - 1) * 50} width="164" height="42" rx="4" fill="#22d3ee" opacity="0.08"/>

              {/* image */}
              <image
                href={v.src}
                x="200" y="88" width="580" height="380"
                preserveAspectRatio="xMidYMid slice"
                clip-path="url(#surveyImgClip)"
              />
              <rect x="200" y="88" width="580" height="380" rx="4" fill="#0a0c10" opacity="0.22" clip-path="url(#surveyImgClip)"/>

              {/* annotation boxes */}
              {v.boxes.map((b) => (
                <>
                  <rect x={b.x} y={b.y} width={b.w} height={b.h} fill="none" stroke={colorMap[b.color]} stroke-width="2.5"/>
                  <text x={b.x} y={b.y - 5} fill={colorMap[b.color]} font-family="monospace" font-size="11">{b.label}</text>
                </>
              ))}
            </g>
          ))}

          {/* image footer badge (always visible) */}
          <g transform="translate(212, 100)">
            <rect x="0" y="0" width="64" height="20" rx="10" fill="#0a0c10" stroke="#22d3ee" opacity="0.85"/>
            <circle cx="11" cy="10" r="3" fill="#22d3ee"/>
            <text x="20" y="14" fill="#22d3ee" font-family="monospace" font-size="9" font-weight="600">LIVE · AI</text>
          </g>

          {/* ====== THUMBNAILS ====== */}
          {views.map((v, i) => {
            const tx = 200 + i * 90;
            return (
              <g class="thumb" data-target={v.id} style="cursor:pointer">
                <defs>
                  <clipPath id={`thumbClip-${v.id}`}>
                    <rect x={tx} y="482" width="80" height="40" rx="2" />
                  </clipPath>
                </defs>
                <rect x={tx} y="482" width="80" height="40" rx="2" fill="#1e293b"/>
                <image
                  href={v.src}
                  x={tx} y="482" width="80" height="40"
                  preserveAspectRatio="xMidYMid slice"
                  clip-path={`url(#thumbClip-${v.id})`}
                  opacity="0.85"
                />
                <rect
                  class="thumb-frame"
                  x={tx} y="482" width="80" height="40" rx="2"
                  fill="none"
                  stroke={i === 0 ? '#22d3ee' : 'transparent'}
                  stroke-width="1.5"
                />
              </g>
            );
          })}
        </svg>
        <figcaption class="mt-3 text-sm text-slate-400">
          Survey detail — AI-drafted annotations on top of captured imagery. <span class="text-slate-500">Click a sidebar item or thumbnail to switch defects.</span>
        </figcaption>
      </figure>

      {/* Mockup 2: 3D reconstruction (point cloud) */}
      <figure>
        <svg viewBox="0 0 800 500" class="w-full rounded-lg border border-slate-800" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="3D reconstruction mockup">
          <rect x="0" y="0" width="800" height="32" fill="#11141a"/>
          <circle cx="16" cy="16" r="4" fill="#475569"/>
          <circle cx="32" cy="16" r="4" fill="#475569"/>
          <circle cx="48" cy="16" r="4" fill="#475569"/>
          <rect x="200" y="10" width="400" height="14" rx="3" fill="#1e293b"/>
          <rect x="0" y="32" width="800" height="468" fill="#0a0c10"/>
          {/* toolbar */}
          <rect x="16" y="48" width="80" height="24" rx="3" fill="#11141a" stroke="#1e293b"/>
          <text x="32" y="64" fill="#94a3b8" font-family="monospace" font-size="10">distance</text>
          <rect x="104" y="48" width="60" height="24" rx="3" fill="#11141a" stroke="#1e293b"/>
          <text x="116" y="64" fill="#94a3b8" font-family="monospace" font-size="10">area</text>
          <rect x="172" y="48" width="60" height="24" rx="3" fill="#11141a" stroke="#22d3ee"/>
          <text x="184" y="64" fill="#22d3ee" font-family="monospace" font-size="10">volume</text>
          {/* point cloud — dot grid with elevation gradient */}
          <g>
            {Array.from({ length: 320 }).map((_, i) => {
              const x = 80 + (i % 32) * 20 + Math.sin(i * 0.7) * 6;
              const y = 110 + Math.floor(i / 32) * 35 + Math.cos(i * 0.4) * 8;
              const t = (Math.sin(i * 0.3) + 1) / 2;
              const colors = ['#0e7490', '#22d3ee', '#67e8f9', '#f59e0b'];
              const fill = colors[Math.floor(t * colors.length) % colors.length];
              return <circle cx={x} cy={y} r={1.4} fill={fill} />;
            })}
          </g>
        </svg>
        <figcaption class="mt-3 text-sm text-slate-400">3D reconstruction — photogrammetry-derived point clouds, viewable directly in the browser.</figcaption>
      </figure>

      {/* Mockup 3: Work orders dashboard */}
      <figure>
        <svg viewBox="0 0 800 500" class="w-full rounded-lg border border-slate-800" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Work orders dashboard mockup">
          <rect x="0" y="0" width="800" height="32" fill="#11141a"/>
          <circle cx="16" cy="16" r="4" fill="#475569"/>
          <circle cx="32" cy="16" r="4" fill="#475569"/>
          <circle cx="48" cy="16" r="4" fill="#475569"/>
          <rect x="200" y="10" width="400" height="14" rx="3" fill="#1e293b"/>
          <rect x="0" y="32" width="800" height="468" fill="#0a0c10"/>
          <text x="32" y="76" fill="#e5e7eb" font-family="sans-serif" font-size="20" font-weight="600">Work orders</text>
          {['Open', 'Assigned', 'In progress', 'Completed'].map((label, ci) => {
            const x = 32 + ci * 190;
            return (
              <g>
                <text x={x} y={120} fill="#94a3b8" font-family="monospace" font-size="11">{label.toUpperCase()}</text>
                {[0, 1, 2].map((ri) => {
                  const y = 140 + ri * 90;
                  const pillColors = ['#22d3ee', '#f59e0b', '#a78bfa'];
                  return (
                    <g>
                      <rect x={x} y={y} width={170} height={70} rx={6} fill="#11141a" stroke="#1f2937"/>
                      <text x={x + 12} y={y + 22} fill="#e5e7eb" font-family="monospace" font-size="10">WO-{1000 + ci * 3 + ri}</text>
                      <text x={x + 12} y={y + 40} fill="#94a3b8" font-family="sans-serif" font-size="10">Cracked insulator</text>
                      <rect x={x + 12} y={y + 50} width={50} height={14} rx={3} fill="none" stroke={pillColors[ri % pillColors.length]}/>
                      <text x={x + 18} y={y + 60} fill={pillColors[ri % pillColors.length]} font-family="monospace" font-size="8">P{ri + 1}</text>
                    </g>
                  );
                })}
              </g>
            );
          })}
        </svg>
        <figcaption class="mt-3 text-sm text-slate-400">Work orders — kanban view with priority pills and auto-routing per defect type.</figcaption>
      </figure>
    </div>
  </div>
</section>

<script>
  const mockup = document.getElementById('surveyMockup');
  if (mockup) {
    const views = mockup.querySelectorAll<SVGGElement>('.survey-view');
    const toolbarMetas = mockup.querySelectorAll<SVGGElement>('.toolbar-meta');
    const thumbs = mockup.querySelectorAll<SVGGElement>('.thumb');
    const sidebarItems = mockup.querySelectorAll<SVGGElement>('.sidebar-item');

    const select = (target: string) => {
      views.forEach((v) => {
        v.style.display = v.getAttribute('data-view') === target ? '' : 'none';
      });
      toolbarMetas.forEach((m) => {
        m.style.display = m.getAttribute('data-view') === target ? '' : 'none';
      });
      thumbs.forEach((t) => {
        const frame = t.querySelector('.thumb-frame');
        if (!frame) return;
        const active = t.getAttribute('data-target') === target;
        frame.setAttribute('stroke', active ? '#22d3ee' : 'transparent');
      });
    };

    const bind = (el: SVGGElement) => {
      el.setAttribute('tabindex', '0');
      el.setAttribute('role', 'button');
      el.addEventListener('click', () => {
        const target = el.getAttribute('data-target');
        if (target) select(target);
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const target = el.getAttribute('data-target');
          if (target) select(target);
        }
      });
    };

    thumbs.forEach(bind);
    sidebarItems.forEach(bind);
  }
</script>
